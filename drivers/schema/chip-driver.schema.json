{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flashbang.local/schema/chip-driver.schema.json",
  "title": "FlashBang Chip Driver Descriptor",
  "type": "object",
  "required": [
    "id",
    "family",
    "name",
    "sector_size_bytes",
    "sequences",
    "models"
  ],
  "properties": {
    "id": {"type": "string"},
    "family": {"type": "string"},
    "name": {"type": "string"},
    "sector_size_bytes": {"type": "integer", "minimum": 1},
    "address_bits": {"type": "integer", "minimum": 1, "maximum": 24},
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["jedec_id", "name", "size_bytes"],
        "properties": {
          "jedec_id": {"type": "string", "pattern": "^0x[0-9A-Fa-f]{4}$"},
          "name": {"type": "string"},
          "size_bytes": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "sequences": {
      "type": "object",
      "required": ["id_entry", "id_read", "id_exit", "program_byte", "sector_erase", "chip_erase"],
      "properties": {
        "id_entry": {"type": "string"},
        "id_read": {"type": "string"},
        "id_exit": {"type": "string"},
        "program_byte": {"type": "string"},
        "program_range": {"type": "string"},
        "sector_erase": {"type": "string"},
        "chip_erase": {"type": "string"}
      },
      "additionalProperties": {"type": "string"}
    },
    "custom_params": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "default"],
        "properties": {
          "name": {"type": "string"},
          "default": {"type": "integer"}
        },
        "additionalProperties": false
      },
      "maxItems": 8
    },
    "operations": {
      "type": "object",
      "properties": {
        "read": {"type": "boolean"},
        "program_byte": {"type": "boolean"},
        "sector_erase": {"type": "boolean"},
        "chip_erase": {"type": "boolean"},
        "write_status": {"type": "boolean"},
        "chip_id": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "timing": {
      "type": "object",
      "properties": {
        "program_timeout_ms": {"type": "integer", "minimum": 1},
        "sector_erase_timeout_ms": {"type": "integer", "minimum": 1},
        "chip_erase_timeout_ms": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
